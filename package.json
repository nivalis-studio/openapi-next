{
	"name": "@nivalis/openapi-next",
	"type": "module",
	"version": "2.0.0-beta.2",
	"description": "Route wrappers for Next.js",
	"license": "MIT",
	"packageManager": "pnpm@10.33.0",
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://github.com/nivalis-studio/openapi-next#readme",
	"repository": {
		"url": "git+https://github.com/nivalis-studio/openapi-next.git"
	},
	"bugs": {
		"url": "https://github.com/nivalis-studio/openapi-next/issues"
	},
	"bin": {
		"openapi-next": "dist/cli/bin.js"
	},
	"scripts": {
		"dev": "bun run --watch src/index.tsx",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"openapi": "bun scripts/generate-openapi.ts",
		"openapi:codegen-smoke": "bun scripts/openapi-codegen-smoke.ts",
		"test": "bun test",
		"build": "zshy",
		"prepack": "zshy",
		"prepare": "lefthook install",
		"ts": "tsc --noEmit --incremental"
	},
	"dependencies": {
		"effect": "3.21.0",
		"es-toolkit": "1.45.1",
		"openapi-types": "12.1.3",
		"prettier": "3.8.1",
		"qs": "6.15.0",
		"zod": "4.3.6"
	},
	"peerDependencies": {
		"next": "^16.0.3",
		"typescript": "^5.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@commitlint/cli": "20.5.0",
		"@commitlint/config-conventional": "20.5.0",
		"@hey-api/openapi-ts": "0.95.0",
		"@nivalis/biome-config": "2.4.10",
		"@total-typescript/ts-reset": "0.6.1",
		"@types/bun": "1.3.11",
		"@types/node": "22.2.0",
		"@types/qs": "6.15.0",
		"lefthook": "2.1.4",
		"next": "16.0.3",
		"taze": "19.11.0",
		"typescript": "5.9.3",
		"zshy": "0.7.0"
	},
	"zshy": {
		"exports": {
			".": "./src/index.ts",
			"./cli/bin": "./src/cli/bin.ts"
		}
	},
	"files": ["dist"],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.cts",
	"exports": {
		".": {
			"types": "./dist/index.d.cts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./cli/bin": {
			"types": "./dist/cli/bin.d.cts",
			"import": "./dist/cli/bin.js",
			"require": "./dist/cli/bin.cjs"
		}
	}
}
